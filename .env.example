# Upstox OAuth (for auth_service)
UPSTOX_CLIENT_ID=
UPSTOX_CLIENT_SECRET=
UPSTOX_REDIRECT_HOST=localhost
UPSTOX_REDIRECT_PORT=8080
UPSTOX_REDIRECT_PATH=/upstox_auth

# Streaming service (stream_service)
UPSTOX_ACCESS_TOKEN=
UPSTOX_INSTRUMENT_FILE=complete_data_formatted.json
UPSTOX_STREAM_MODE=ltpc

# TimescaleDB
UPSTOX_PG_DSN=postgresql://postgres:admin123@localhost:5432/market_data
UPSTOX_PG_BATCH=1000
UPSTOX_PG_FLUSH_INTERVAL=0.5

# Redis cache
UPSTOX_REDIS_URL=redis://localhost:6379/0
UPSTOX_REDIS_TTL=10

# SMTP alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER=
SMTP_RECIPIENTS=
